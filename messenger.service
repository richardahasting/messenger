[Unit]
Description=Messenger — agent-to-agent messaging daemon
After=network.target

[Service]
Type=simple
User=richard
WorkingDirectory=/home/richard/projects/messenger
ExecStart=/usr/bin/java -jar /home/richard/projects/messenger/target/messenger.jar
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal

# Pass OpenBrain key from environment
EnvironmentFile=-/home/richard/projects/messenger/.env

[Install]
WantedBy=multi-user.target
